# Server
PORT=8080
API_BASE_URL=https://your-api.onrender.com
FRONTEND_URL=https://your-app.vercel.app

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=another_super_secret_key_for_refresh_tokens
JWT_REFRESH_EXPIRY=168h

# AI APIs
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio
GROQ_API_KEY=your_groq_api_key_from_groq_cloud

# Email (Brevo / Sendinblue)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=AI Symptom Checker

# Keep-Alive (optional — defaults shown)
DB_PING_INTERVAL=120h
SELF_PING_INTERVAL=10m
